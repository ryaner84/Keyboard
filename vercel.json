{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "crons": [
    {
      "path": "/api/currencies?force=true",
      "schedule": "15 16 * * *"
    },
    {
      "path": "/api/cron/refresh",
      "schedule": "0 16 * * *"
    },
    {
      "path": "/api/cron/lightning",
      "schedule": "30 16 * * *"
    }
  ]
}
