generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum GBStatus {
  INTEREST_CHECK
  ACTIVE_GB
  SHIPPING
  DELIVERED
  IN_STOCK
  CANCELLED
}

enum KitType {
  BASE
  NUMPAD
  MAC
  NOVELTIES
  SPACEBARS
  ISO
  ADDON
}

enum Region {
  US
  CA
  EU
  UK
  AU
  SG
  ASIA
  OTHER
}

model GroupBuy {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  subtitle    String?
  colorway    String?
  designer    String
  status      GBStatus
  gbStart     DateTime?
  gbEnd       DateTime?
  imageUrl    String?
  images      String[]  @default([])
  // When the gmk.net gallery was last (re)checked — rotates scraper attention
  // oldest-first and lets previously-scraped galleries self-heal over time.
  imagesUpdatedAt DateTime?
  description String?
  featured    Boolean   @default(false)
  // "KEYCAPS" (default) or "KEYBOARD". Drives category filter and determines
  // which set-detail layout to render (price-compare vs dev-tracker).
  productType String    @default("KEYCAPS")
  // Keyboard-specific spec fields (null for keycap sets).
  layout      String?   // e.g. "TKL", "65%", "75%", "60%", "Full-size"
  material    String?   // e.g. "Aluminum", "Polycarbonate", "PC + Brass"
  mountingStyle String? // e.g. "Top Mount", "Gasket Mount", "Tray Mount"
  // Keyboard pricing/vendor fields. Unlike keycaps (multi-vendor price compare),
  // a keyboard GB is sold by a single store, so price lives directly on the row.
  basePrice     Float?  // lowest variant price in the vendor's native currency
  priceCurrency String? // ISO code of basePrice, e.g. "USD", "SGD", "CNY"
  productUrl    String? // direct link to the product/GB page to actually buy
  vendorName    String? // store running the GB, e.g. "NovelKeys", "Prototypist"
  vendorRegion  String? // origin region for shipping estimate: US/EU/SG/ASIA/...
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  kits        Kit[]
  devUpdates  DevUpdate[]
}

model Kit {
  id         String      @id @default(cuid())
  name       String
  type       KitType
  groupBuyId String
  groupBuy   GroupBuy    @relation(fields: [groupBuyId], references: [id], onDelete: Cascade)
  vendorKits VendorKit[]
}

model Vendor {
  id               String         @id @default(cuid())
  name             String
  slug             String         @unique
  region           Region
  country          String
  currency         String
  websiteUrl       String
  logoUrl          String?
  // When the catalog discovery crawler last scanned this store for GMK
  // listings — rotates crawler attention oldest-first across nightly runs.
  lastDiscoveredAt DateTime?
  vendorKits       VendorKit[]
  shippingZones    ShippingZone[]
}

model VendorKit {
  id             String    @id @default(cuid())
  kitId          String
  kit            Kit       @relation(fields: [kitId], references: [id], onDelete: Cascade)
  vendorId       String
  vendor         Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  price          Float?
  currency       String?
  inStock        Boolean   @default(true)
  gbUrl          String?
  productUrl     String?
  priceUpdatedAt DateTime?
  priceSource    String? // "LIVE" | "SCRAPED" | "MANUAL"
  // All Shopify variants scraped from the product page: [{ title, price }].
  // Powers the kit-category filter (Base / Alpha / Novelties / Spacebars / Others).
  variants       Json?
  notes          String?
  updatedAt      DateTime  @updatedAt

  @@unique([kitId, vendorId])
}

model ShippingZone {
  id                String  @id @default(cuid())
  vendorId          String
  vendor            Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  destinationRegion Region
  baseShippingCost  Float
  currency          String
  estimatedDaysMin  Int
  estimatedDaysMax  Int
  shipsToRegion     Boolean @default(true)

  @@unique([vendorId, destinationRegion])
}

model Currency {
  code              String   @id
  name              String
  symbol            String
  exchangeRateToUSD Float
  lastUpdated       DateTime @default(now())
}

// Crowd-sourced vendor product URLs submitted via the "Add vendor link" panel.
// The nightly refresh turns unprocessed rows into scrapeable VendorKits.
model VendorSuggestion {
  id          String   @id @default(cuid())
  slug        String
  productUrl  String
  vendorName  String?
  submittedAt DateTime @default(now())
  processed   Boolean  @default(false)
}

// Visitor feedback from the header "Feedback" panel. Write-only from the site
// (no public read API) — view the rows directly in Supabase.
model Feedback {
  id          String   @id @default(cuid())
  email       String
  subject     String
  submittedAt DateTime @default(now())
}

// Community-contributed tip for the keyboard database.
// A visitor pastes a URL (vendor page, group buy listing, zFrontier post, etc.)
// or a free-text description of a keyboard they know about. The site owner
// reviews and triggers a targeted scrape or manual entry.
model KeyboardContribution {
  id          String   @id @default(cuid())
  content     String   // URL or free-text tip — either format accepted
  handle      String?  // optional "Discord handle / name to credit"
  submittedAt DateTime @default(now())
  processed   Boolean  @default(false)
}

// Development update / changelog entry for a keyboard group buy.
// Designers post updates (tooling confirmation, prototype photos, PCB tests,
// shipping timelines) between GB close and delivery — this captures those.
model DevUpdate {
  id          String    @id @default(cuid())
  groupBuyId  String
  groupBuy    GroupBuy  @relation(fields: [groupBuyId], references: [id], onDelete: Cascade)
  title       String
  content     String
  // Short milestone tag shown as a badge: "Tooling", "Prototype", "PCB Testing",
  // "Shipping", "Delivered", "Announcement", "IC", "GB", "Extra Sale", etc.
  milestone   String?
  imageUrls   String[]  @default([])
  postedAt    DateTime  @default(now())
  createdAt   DateTime  @default(now())

  @@index([groupBuyId, postedAt])
}

// User-submitted wrong-price reports on a specific vendor row.
// Write-only from the site — view rows in Supabase to triage data issues.
model PriceReport {
  id           String   @id @default(cuid())
  setSlug      String
  vendorKitId  String
  vendorName   String
  reason       String?
  submittedAt  DateTime @default(now())
}
