generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum GBStatus {
  INTEREST_CHECK
  ACTIVE_GB
  SHIPPING
  DELIVERED
  IN_STOCK
  CANCELLED
}

enum KitType {
  BASE
  NUMPAD
  MAC
  NOVELTIES
  SPACEBARS
  ISO
  ADDON
}

enum Region {
  US
  CA
  EU
  UK
  AU
  SG
  ASIA
  OTHER
}

model GroupBuy {
  id              String        @id @default(cuid())
  slug            String        @unique
  name            String
  subtitle        String?
  colorway        String?
  designer        String
  status          GBStatus
  gbStart         DateTime?
  gbEnd           DateTime?
  imageUrl        String?
  images          String[]      @default([])
  // When the gmk.net gallery was last (re)checked — rotates scraper attention
  // oldest-first and lets previously-scraped galleries self-heal over time.
  imagesUpdatedAt DateTime?
  description     String?
  featured        Boolean       @default(false)
  // "KEYCAPS" (default) or "KEYBOARD". Drives category filter and determines
  // which set-detail layout to render (price-compare vs dev-tracker).
  productType     String        @default("KEYCAPS")
  // Keyboard-specific spec fields (null for keycap sets).
  layout          String? // e.g. "TKL", "65%", "75%", "60%", "Full-size"
  material        String? // e.g. "Aluminum", "Polycarbonate", "PC + Brass"
  mountingStyle   String? // e.g. "Top Mount", "Gasket Mount", "Tray Mount"
  // Keyboard pricing/vendor fields. Unlike keycaps (multi-vendor price compare),
  // a keyboard GB is sold by a single store, so price lives directly on the row.
  basePrice       Float? // lowest variant price in the vendor's native currency
  priceCurrency   String? // ISO code of basePrice, e.g. "USD", "SGD", "CNY"
  productUrl      String? // direct link to the product/GB page to actually buy
  vendorName      String? // store running the GB, e.g. "NovelKeys", "Prototypist"
  vendorRegion    String? // origin region for shipping estimate: US/EU/SG/ASIA/...
  // Source/trust metadata. Geekhack forum threads can go stale without the
  // title changing, so lifecycle status and data confidence are tracked
  // separately.
  sourceType           String? // "GEEKHACK" | "KEYCAPLENDAR" | "VENDOR" | null
  sourceUrl            String?
  sourceLastCheckedAt  DateTime?
  sourceLastActivityAt DateTime?
  dataTrustLevel       String        @default("TRUSTED") // TRUSTED | CAUTION | STALE | DEAD
  dataTrustReason      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  kits            Kit[]
  devUpdates      DevUpdate[]
  trackerItems    TrackerItem[]

  @@index([dataTrustLevel])
  @@index([sourceType])
}

model Kit {
  id         String      @id @default(cuid())
  name       String
  type       KitType
  groupBuyId String
  groupBuy   GroupBuy    @relation(fields: [groupBuyId], references: [id], onDelete: Cascade)
  vendorKits VendorKit[]
}

model Vendor {
  id               String         @id @default(cuid())
  name             String
  slug             String         @unique
  region           Region
  country          String
  currency         String
  websiteUrl       String
  logoUrl          String?
  // When the catalog discovery crawler last scanned this store for GMK
  // listings — rotates crawler attention oldest-first across nightly runs.
  lastDiscoveredAt DateTime?
  vendorKits       VendorKit[]
  shippingZones    ShippingZone[]
}

model VendorKit {
  id             String    @id @default(cuid())
  kitId          String
  kit            Kit       @relation(fields: [kitId], references: [id], onDelete: Cascade)
  vendorId       String
  vendor         Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  price          Float?
  currency       String?
  inStock        Boolean   @default(true)
  gbUrl          String?
  productUrl     String?
  priceUpdatedAt DateTime?
  priceSource    String? // "LIVE" | "SCRAPED" | "MANUAL"
  // All Shopify variants scraped from the product page: [{ title, price }].
  // Powers the kit-category filter (Base / Alpha / Novelties / Spacebars / Others).
  variants       Json?
  notes          String?
  updatedAt      DateTime  @updatedAt

  @@unique([kitId, vendorId])
}

model ShippingZone {
  id                String  @id @default(cuid())
  vendorId          String
  vendor            Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  destinationRegion Region
  baseShippingCost  Float
  currency          String
  estimatedDaysMin  Int
  estimatedDaysMax  Int
  shipsToRegion     Boolean @default(true)

  @@unique([vendorId, destinationRegion])
}

model Currency {
  code              String   @id
  name              String
  symbol            String
  exchangeRateToUSD Float
  lastUpdated       DateTime @default(now())
}

// Crowd-sourced vendor product URLs submitted via the "Add vendor link" panel.
// The nightly refresh turns unprocessed rows into scrapeable VendorKits.
model VendorSuggestion {
  id          String   @id @default(cuid())
  slug        String
  productUrl  String
  vendorName  String?
  submittedAt DateTime @default(now())
  processed   Boolean  @default(false)
}

// Visitor feedback from the header "Feedback" panel. Write-only from the site
// (no public read API) — view the rows directly in Supabase.
model Feedback {
  id          String   @id @default(cuid())
  email       String
  subject     String
  submittedAt DateTime @default(now())
  // Triage state for the visitor-inbox feed. NULL = unresolved; cleared
  // manually (feedback has no derivable auto-resolution signal).
  resolvedAt  DateTime?
}

// Community-contributed tip for the keyboard database.
// A visitor pastes a URL (vendor page, group buy listing, zFrontier post, etc.)
// or a free-text description of a keyboard they know about. The site owner
// reviews and triggers a targeted scrape or manual entry.
model KeyboardContribution {
  id          String   @id @default(cuid())
  content     String // URL or free-text tip — either format accepted
  handle      String? // optional "Discord handle / name to credit"
  submittedAt DateTime @default(now())
  processed   Boolean  @default(false)
}

// Development update / changelog entry for a keyboard group buy.
// Designers post updates (tooling confirmation, prototype photos, PCB tests,
// shipping timelines) between GB close and delivery — this captures those.
model DevUpdate {
  id         String   @id @default(cuid())
  groupBuyId String
  groupBuy   GroupBuy @relation(fields: [groupBuyId], references: [id], onDelete: Cascade)
  title      String
  content    String
  // Short milestone tag shown as a badge: "Tooling", "Prototype", "PCB Testing",
  // "Shipping", "Delivered", "Announcement", "IC", "GB", "Extra Sale", etc.
  milestone  String?
  imageUrls  String[] @default([])
  postedAt   DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([groupBuyId, postedAt])
}

// General listing-quality reports submitted by visitors.
// Covers wrong category, stale GBs, duplicates, wrong vendor, etc.
// Write-only from the site — query in Supabase for the daily triage routine.
model ListingReport {
  id          String   @id @default(cuid())
  slug        String
  name        String
  issueType   String // "wrong_category" | "wrong_price" | "inactive" | "duplicate" | "wrong_vendor" | "other"
  notes       String?
  submittedAt DateTime @default(now())
  // Triage state for the visitor-inbox feed. NULL = unresolved (surfaced to the
  // owner); set to clear it. No derivable auto-resolution — cleared manually.
  resolvedAt  DateTime?

  @@index([submittedAt])
}

// User-submitted wrong-price reports on a specific vendor row.
// Write-only from the site — view rows in Supabase to triage data issues.
model PriceReport {
  id          String   @id @default(cuid())
  setSlug     String
  vendorKitId String
  vendorName  String
  reason      String?
  submittedAt DateTime @default(now())
  // Triage state for the visitor-inbox feed. Auto-resolved once the reported
  // listing's bad price is gone (VendorKit deleted or price nulled).
  resolvedAt  DateTime?
}

// Passwordless tracker identity. Email is the only user-facing identifier;
// admin authentication remains completely separate.
model TrackerUser {
  id                  String   @id @default(cuid())
  email               String   @unique
  alertsEnabled       Boolean  @default(true)
  countryCode         String?
  region              String?
  currency            String?
  displayName         String?
  collectionSlug      String?  @unique
  collectionTitle     String?
  collectionBio      String?
  collectionPublished Boolean @default(false)
  verifiedAt          DateTime
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  items         TrackerItem[]
  notifications TrackerNotification[]
}

// One-time magic-link and OTP challenge. Tokens are stored only as hashes.
model TrackerAuthChallenge {
  id             String    @id @default(cuid())
  email          String
  magicTokenHash String    @unique
  otpHash        String
  attempts       Int       @default(0)
  ipHash         String?
  pendingSlugs   String[]  @default([])
  countryCode    String?
  region         String?
  currency       String?
  expiresAt      DateTime
  consumedAt     DateTime?
  requestedAt    DateTime  @default(now())

  @@index([email, requestedAt])
  @@index([expiresAt])
}

model TrackerItem {
  id                String    @id @default(cuid())
  userId            String
  groupBuyId        String
  alertsEnabled     Boolean   @default(true)
  isTracking        Boolean   @default(true)
  inCollection      Boolean   @default(false)
  isPublic          Boolean   @default(false)
  acquiredAt        DateTime?
  condition         String?
  purchasePrice     Float?
  purchaseCurrency  String?
  showPurchasePrice Boolean   @default(false)
  switches          String?
  keycaps           String?
  buildDetails      String?
  notes             String?
  displayOrder      Int       @default(0)
  color             String?
  quantity          Int       @default(1)
  // The owner's own photo for this piece (build 1), overriding the catalog
  // image on their card. Stored as a resized data: URL.
  customImageUrl    String?
  // Build indexes (0-based) EXCLUDED from the public collection page — lets
  // an owner publish only selected units of a multi-unit piece. Null/empty
  // means every build is shown.
  hiddenBuilds      Json?
  // Per-unit build breakdown for quantity > 1. JSON array of builds 2..N
  // (build 1 lives in the columns above): [{ acquiredAt, purchasePrice,
  // purchaseCurrency, color, condition, switches, keycaps, buildDetails,
  // notes, imageUrl }].
  units             Json?
  // Keycap-set purchase records. Unlike a keyboard's per-unit builds, a
  // keycap collection entry can contain several purchases with their own
  // kits, total paid, photo, condition, and optional keyboard pairing.
  keycapAcquisitions Json?
  lastStatus        String?
  lastBestPriceUsd  Float?
  lastVendorCount   Int       @default(0)
  lastDevUpdateAt   DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user          TrackerUser           @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupBuy      GroupBuy              @relation(fields: [groupBuyId], references: [id], onDelete: Cascade)
  notifications TrackerNotification[]
  photoReports  CollectionPhotoReport[]

  @@unique([userId, groupBuyId])
  @@index([groupBuyId])
}

// Visitor reports tied to the exact owner-uploaded image that was visible when
// the report was submitted. imageHash prevents a replacement photo from
// inheriting reports made against the previous upload.
model CollectionPhotoReport {
  id             String   @id @default(cuid())
  trackerItemId  String
  collectionSlug String
  buildIndex     Int      @default(0)
  imageHash      String
  issueType      String
  notes          String?
  reporterIpHash String?
  reporterUserId String?
  submittedAt    DateTime @default(now())
  // Triage state for the visitor-inbox feed. NULL = unresolved; cleared
  // manually. Reports are also auto-removed by the FK cascade if the build
  // photo's tracker item is deleted.
  resolvedAt     DateTime?

  trackerItem TrackerItem @relation(fields: [trackerItemId], references: [id], onDelete: Cascade)

  @@index([trackerItemId, imageHash, submittedAt])
  @@index([submittedAt])
}

model TrackerNotification {
  id            String    @id @default(cuid())
  userId        String
  trackerItemId String?
  type          String
  title         String
  body          String
  fingerprint   String    @unique
  createdAt     DateTime  @default(now())
  sentAt        DateTime?

  user        TrackerUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  trackerItem TrackerItem? @relation(fields: [trackerItemId], references: [id], onDelete: SetNull)

  @@index([userId, sentAt])
}
