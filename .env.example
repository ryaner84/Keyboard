# Supabase PostgreSQL connection (Transaction pooler URL from Supabase dashboard)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase direct connection (Session pooler or direct URL)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Exchange rate API key — free at https://www.exchangerate-api.com
EXCHANGE_RATE_API_KEY="your_api_key_here"

# Admin password (bcrypt hash of your chosen password)
# Generate with: node -e "const b=require('bcryptjs'); b.hash('yourpassword',10).then(console.log)"
ADMIN_PASSWORD_HASH="$2a$10$..."

# JWT secret for admin session cookies
JWT_SECRET="a-long-random-secret-string-here"

# Separate secret for 30-day personal tracker session cookies and unsubscribe links
TRACKER_AUTH_SECRET="another-long-random-secret-string-here"

# Managed email delivery for tracker magic links, OTPs, and alerts
RESEND_API_KEY="re_..."
# Optional only after verifying a custom sending domain in Resend.
# If omitted, passwordless login uses Resend's sandbox sender and can email
# only the address that owns the Resend account.
# TRACKER_EMAIL_FROM="GMK Tracker <tracker@your-domain.com>"
# TRACKER_EMAIL_REPLY_TO="support@your-domain.com"

# Public site URL (used for QR codes and OG tags)
NEXT_PUBLIC_SITE_URL="https://your-site.vercel.app"

# Secret protecting the daily import/price-refresh cron (/api/cron/refresh).
# Vercel sends this automatically as a Bearer token for scheduled crons.
CRON_SECRET="another-long-random-secret"

# KeycapLendar Firestore project id (source of real GMK group-buy data)
KEYCAPLENDAR_PROJECT_ID="keycaplendar"
